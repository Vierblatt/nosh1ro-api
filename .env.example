# 数据库（支持 MySQL / SQLite，通过 DB_TYPE 切换）
DB_TYPE=mysql
DB_DSN=root:password@tcp(127.0.0.1:3306)/blog?charset=utf8mb4&parseTime=true&loc=Local

# JWT 认证（必需）
JWT_SECRET=change-me-in-production
ADMIN_PASSWORD=change-me-in-production
ADMIN_USERNAME=admin

# 博客
BLOG_TITLE=nosh1ro
PORT=8080

# 邮件（SMTP，注册验证用）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-email@qq.com
BASE_URL=http://localhost:8080

# Elasticsearch（可选，不填则自动降级到 SQL 搜索）
ES_URL=http://127.0.0.1:9200

# Redis（可选，不填则使用内存令牌桶限流）
REDIS_URL=redis://127.0.0.1:6379

# RabbitMQ（可选，不填则跳过事件驱动）
RABBITMQ_URL=amqp://blog:blog@127.0.0.1:5672/
